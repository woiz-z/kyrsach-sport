# Backend API URL — used as a build-time argument (VITE_API_URL)
# If empty, the nginx proxy handles /api → BACKEND_URL at runtime
VITE_API_URL=

# Runtime nginx proxy target — set this in Railway to the backend service's private URL
# e.g. https://backend.railway.internal  or  https://your-backend.up.railway.app
BACKEND_URL=http://localhost:8000
