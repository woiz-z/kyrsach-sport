# Database — Railway sets this automatically if you add a PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sports_predict

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI providers (optional — predictions still work without these)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Data sync
AUTO_SYNC_REAL_DATA=true
AUTO_SIMULATE_PAST_MATCHES=false

# Email (password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Frontend URL — used in password-reset emails and CORS
FRONTEND_URL=https://your-frontend.up.railway.app
# Comma-separated extra CORS origins if needed
EXTRA_CORS_ORIGINS=

# Avatar cache (leave default on Railway)
AVATAR_CACHE_DIR=/var/cache/sportpredict/avatars
